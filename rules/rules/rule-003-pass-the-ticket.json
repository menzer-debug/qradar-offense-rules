{
  "rule_name": "Pass-the-Ticket Detection",
  "description": "Detects Kerberos ticket usage from multiple IPs for same user",
  "log_source": "Authentication Logs",
  "conditions": [
    {
      "type": "anomaly",
      "event": "Kerberos TGT Usage",
      "same_user_multiple_ips": true,
      "time_window": "5 minutes"
    }
  ],
  "response": {
    "create_offense": true,
    "severity": 8,
    "relevance": 8,
    "credibility": 7,
    "magnitude": 8
  }
}
